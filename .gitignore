# API Keys — MOST IMPORTANT 
# These files should never be committed.
# Store API keys in these files locally and keep them here.
secrets.properties
api-keys.properties
youtube-key.txt
config-secret.properties

# Uploaded Card Images
# Comment this out if you want to commit seed images.
# Uncomment to prevent large image files from being tracked.
# src/main/webapp/images/cards/*.png
# src/main/webapp/images/cards/*.jpg
# src/main/webapp/images/cards/*.jpeg
# src/main/webapp/images/cards/*.gif
# src/main/webapp/images/cards/*.webp

# JARs in WEB-INF/lib
# Uncomment if you are using Maven and JARs are declared
# in pom.xml — they should not be committed then.
# src/main/webapp/WEB-INF/lib/*.jar

