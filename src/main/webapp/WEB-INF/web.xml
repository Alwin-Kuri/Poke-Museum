<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
             https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0"
         metadata-complete="true">

    <display-name>PokéMuseum</display-name>

    <!-- /css/* -> src/main/webapp/css/
         /js/* -> src/main/webapp/js/
         /images/* -> src/main/webapp/images/-->
    <servlet>
        <servlet-name>default</servlet-name>
        <servlet-class>org.apache.catalina.servlets.DefaultServlet</servlet-class>
        <init-param>
            <param-name>debug</param-name>
            <param-value>0</param-value>
        </init-param>
        <init-param>
            <param-name>listings</param-name>
            <param-value>false</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>

    <!-- Map static folders explicitly to the default servlet -->
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>/css/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>/js/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>/images/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>/favicon.ico</url-pattern>
    </servlet-mapping>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>


<!--
    All servlets registered:
      Auth    : Login, Logout, Register, ForgotPassword
      Core    : Home, Cards, Pokedex (NEW)
      User    : Inventory, Catch, Booster, Quest, Trade, Deck
      Anime   : Anime (NEW — Jikan + YouTube API)
      Admin   : AdminDashboard, AdminUsers
      Export  : ExportPdf
-->


  <!--WELCOME FILE-->
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

  <!--CUSTOM ERROR PAGES-->
  <error-page>
    <error-code>404</error-code>
    <location>/WEB-INF/pages/error404.jsp</location>
  </error-page>
  <error-page>
    <error-code>500</error-code>
    <location>/WEB-INF/pages/error500.jsp</location>
  </error-page>

  <!-- AUTH FILTER — intercepts all requests
       Declared AFTER default servlet so static files are
       handled first before this filter runs.-->
  <filter>
    <filter-name>AuthFilter</filter-name>
    <filter-class>com.pokemuse.util.AuthFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <!--SERVLET DECLARATIONS -->

  <!-- Auth -->
  <servlet>
    <servlet-name>LoginServlet</servlet-name>
    <servlet-class>com.pokemuse.controller.LoginServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>com.pokemuse.controller.LogoutServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>RegisterServlet</servlet-name>
    <servlet-class>com.pokemuse.controller.RegisterServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>ForgotPasswordServlet</servlet-name>
    <servlet-class>com.pokemuse.controller.ForgotPasswordServlet</servlet-class>
  </servlet>

  <!-- Core -->
  <servlet>
    <servlet-name>HomeServlet</servlet-name>
    <servlet-class>com.pokemuse.controller.HomeServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>CardServlet</servlet-name>
    <servlet-class>com.pokemuse.controller.CardServlet</servlet-class>
  </servlet>

  <!-- PokeAPI Pokédex detail page — NEW -->
  <servlet>
    <servlet-name>PokedexServlet</servlet-name>
    <servlet-class>com.pokemuse.controller.PokedexServlet</servlet-class>
  </servlet>

  <!-- Anime page — Jikan + YouTube — NEW -->
  <servlet>
    <servlet-name>AnimeServlet</servlet-name>
    <servlet-class>com.pokemuse.controller.AnimeServlet</servlet-class>
  </servlet>

  <!-- User features -->
  <servlet>
    <servlet-name>InventoryServlet</servlet-name>
    <servlet-class>com.pokemuse.controller.InventoryServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>CatchServlet</servlet-name>
    <servlet-class>com.pokemuse.controller.CatchServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>BoosterPackServlet</servlet-name>
    <servlet-class>com.pokemuse.controller.BoosterPackServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>QuestServlet</servlet-name>
    <servlet-class>com.pokemuse.controller.QuestServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>TradeServlet</servlet-name>
    <servlet-class>com.pokemuse.controller.TradeServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>DeckServlet</servlet-name>
    <servlet-class>com.pokemuse.controller.DeckServlet</servlet-class>
  </servlet>

  <!-- Admin -->
  <servlet>
    <servlet-name>AdminDashboardServlet</servlet-name>
    <servlet-class>com.pokemuse.controller.AdminDashboardServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>AdminUserServlet</servlet-name>
    <servlet-class>com.pokemuse.controller.AdminUserServlet</servlet-class>
  </servlet>

  <!-- Export -->
  <servlet>
    <servlet-name>ExportPdfServlet</servlet-name>
    <servlet-class>com.pokemuse.controller.ExportPdfServlet</servlet-class>
  </servlet>

  <!--SERVLET MAPPINGS-->

  <!-- Auth -->
  <servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>RegisterServlet</servlet-name>
    <url-pattern>/register</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>ForgotPasswordServlet</servlet-name>
    <url-pattern>/forgot-password</url-pattern>
  </servlet-mapping>

  <!-- Core -->
  <servlet-mapping>
    <servlet-name>HomeServlet</servlet-name>
    <url-pattern>/home</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>HomeServlet</servlet-name>
    <url-pattern>/</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>CardServlet</servlet-name>
    <url-pattern>/cards</url-pattern>
  </servlet-mapping>

  <!-- PokeAPI Pokédex — NEW -->
  <servlet-mapping>
    <servlet-name>PokedexServlet</servlet-name>
    <url-pattern>/pokedex</url-pattern>
  </servlet-mapping>

  <!-- Anime — NEW -->
  <servlet-mapping>
    <servlet-name>AnimeServlet</servlet-name>
    <url-pattern>/anime</url-pattern>
  </servlet-mapping>

  <!-- User features -->
  <servlet-mapping>
    <servlet-name>InventoryServlet</servlet-name>
    <url-pattern>/inventory</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>CatchServlet</servlet-name>
    <url-pattern>/catch</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>BoosterPackServlet</servlet-name>
    <url-pattern>/booster</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>QuestServlet</servlet-name>
    <url-pattern>/quests</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>TradeServlet</servlet-name>
    <url-pattern>/trade</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>DeckServlet</servlet-name>
    <url-pattern>/deck</url-pattern>
  </servlet-mapping>

  <!-- Admin -->
  <servlet-mapping>
    <servlet-name>AdminDashboardServlet</servlet-name>
    <url-pattern>/admin/dashboard</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>AdminUserServlet</servlet-name>
    <url-pattern>/admin/users</url-pattern>
  </servlet-mapping>

  <!-- Export -->
  <servlet-mapping>
    <servlet-name>ExportPdfServlet</servlet-name>
    <url-pattern>/export/pdf</url-pattern>
  </servlet-mapping>

</web-app>
